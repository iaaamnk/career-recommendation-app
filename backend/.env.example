# Django Configuration
SECRET_KEY=your-django-secret-key
DEBUG=True

# Database Configuration (Supabase PostgreSQL or local SQLite)
# Example Supabase Postgres URL: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=sqlite:///sql_app.db

# Supabase API Credentials (from Supabase Dashboard -> Project Settings -> API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
